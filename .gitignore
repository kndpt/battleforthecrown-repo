# Workspace root .gitignore
# Sub-workspaces battleforthecrown/ and battleforthecrown-backend/ have their own
# .git repos and are intentionally tracked elsewhere — ignore them at this level
# until Phase 7 (legacy archive) and Phase 8 (consolidation).

# Sub-repos with their own git history
battleforthecrown/
battleforthecrown-backend/

# Workspace artifacts
node_modules/
dist/
build/
coverage/
.next/
.turbo/
.cache/

# Generated package outputs (kept for runtime, regenerated by yarn install)
packages/shared/dist/

# Editor / OS
.DS_Store
*.log
.vscode/
.idea/
.trae/

# Claude Code per-session state
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Legacy doc — replaced by docs/migration/ + Phase 8 consolidation
WARP.md

# Environment overrides (kept locally only)
*.local
.env.local
.env.*.local
