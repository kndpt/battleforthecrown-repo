# Workspace root .gitignore

# Workspace artifacts
node_modules/
dist/
build/
coverage/
.next/
.turbo/
.cache/

# We use yarn — block npm/pnpm lockfiles from leaking in
package-lock.json
pnpm-lock.yaml

# Generated package outputs (kept for runtime, regenerated by yarn install)
packages/shared/dist/
*.tsbuildinfo

# Editor / OS
.DS_Store
*.log
.vscode/
.idea/
.trae/

# Claude Code per-session state
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/agent-memory/
.claude/projects/

# Legacy doc — replaced by docs/migration/ + Phase 8 consolidation
WARP.md

# Environment overrides (kept locally only)
*.local
.env.local
.env.*.local
