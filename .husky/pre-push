#!/usr/bin/env bash
set -euo pipefail

zero="0000000000000000000000000000000000000000"
needs_check=false
had_ref=false

is_code_change() {
  local file="$1"

  case "$file" in
    battleforthecrown-backend/*|battleforthecrown-pixi/*|packages/*)
      case "$file" in
        *.md|*.txt) return 1 ;;
        *) return 0 ;;
      esac
      ;;
    package.json|yarn.lock|tsconfig.base.json)
      return 0
      ;;
    */package.json|*/tsconfig.json|*/tsconfig.*.json)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

collect_push_files() {
  local local_ref="$1"
  local local_sha="$2"
  local remote_ref="$3"
  local remote_sha="$4"

  case "$local_ref" in
    refs/tags/*) return ;;
  esac

  had_ref=true

  if [ "$remote_sha" = "$zero" ]; then
    local base=""
    base=$(git merge-base "$local_sha" main 2>/dev/null || true)
    if [ -z "$base" ]; then
      base=$(git merge-base "$local_sha" master 2>/dev/null || true)
    fi
    if [ -z "$base" ]; then
      needs_check=true
      return
    fi
    git diff --name-only "$base" "$local_sha"
    return
  fi

  git diff --name-only "$remote_sha" "$local_sha"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if is_code_change "$file"; then
      needs_check=true
      break 2
    fi
  done < <(collect_push_files "$local_ref" "$local_sha" "$remote_ref" "$remote_sha" || true)
done

if [ "$had_ref" = false ]; then
  needs_check=true
fi

if [ "$needs_check" = false ]; then
  echo "[pre-push] Aucun fichier code impacté (doc, tasks, config outil, etc.) — skip static-check et tests."
  exit 0
fi

echo "[pre-push] Running static-check + unit tests (backend + pixi)…"
yarn static-check
yarn test:backend
yarn test:pixi
