#!/usr/bin/env sh
set -eu

zero="0000000000000000000000000000000000000000"
needs_check=false
had_ref=false

is_code_change() {
  case "$1" in
    battleforthecrown-backend/*|battleforthecrown-pixi/*|packages/*)
      case "$1" in
        *.md|*.txt) return 1 ;;
        *) return 0 ;;
      esac
      ;;
    package.json|yarn.lock|tsconfig.base.json)
      return 0
      ;;
    */package.json|*/tsconfig.json|*/tsconfig.*.json)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

collect_push_files() {
  _local_ref="$1"
  _local_sha="$2"
  _remote_sha="$4"

  case "$_local_ref" in
    refs/tags/*) return ;;
  esac

  had_ref=true

  if [ "$_remote_sha" = "$zero" ]; then
    _base=$(git merge-base "$_local_sha" main 2>/dev/null || true)
    if [ -z "$_base" ]; then
      _base=$(git merge-base "$_local_sha" master 2>/dev/null || true)
    fi
    if [ -z "$_base" ]; then
      needs_check=true
      return
    fi
    git diff --name-only "$_base" "$_local_sha"
    return
  fi

  git diff --name-only "$_remote_sha" "$_local_sha"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  for file in $(collect_push_files "$local_ref" "$local_sha" "$remote_ref" "$remote_sha" 2>/dev/null || true); do
    [ -z "$file" ] && continue
    if is_code_change "$file"; then
      needs_check=true
      break 2
    fi
  done
done

if [ "$had_ref" = false ]; then
  needs_check=true
fi

if [ "$needs_check" = false ]; then
  echo "[pre-push] Aucun fichier code impacté (doc, tasks, config outil, etc.) — skip static-check et tests."
  exit 0
fi

echo "[pre-push] Running static-check + unit tests (backend + pixi)…"
yarn static-check
yarn test:backend
yarn test:pixi
