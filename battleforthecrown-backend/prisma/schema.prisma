generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorldStatus {
  PLANNED
  OPEN
  LOCKED
  ENDED
  ARCHIVED
}

enum WorldRole {
  PLAYER
  MOD
}

enum ExpeditionKind {
  ATTACK
  REINFORCE
  SCOUT
  CARAVAN
}

enum ExpeditionStatus {
  EN_ROUTE
  RESOLVED
  RETURNING
}

enum TargetKind {
  PLAYER_VILLAGE
  BARBARIAN_VILLAGE
}

enum RankingSignal {
  ASSAULT_GLORY
  RAMPART_GLORY
}

enum FinalRankingSignal {
  POWER
  ASSAULT_GLORY
  RAMPART_GLORY
}

enum CosmeticAwardKind {
  POWER_CHAMPION_TITLE
  ASSAULT_CHAMPION_TITLE
  RAMPART_CHAMPION_TITLE
}

enum TrainingBuilding {
  BARRACKS
  THRONE_HALL
}

enum PendingConquestStatus {
  OPEN
  COMPLETED
  INTERRUPTED
}

enum VillageLabel {
  OFFENSIVE
  DEFENSIVE
  ECONOMIC
}

enum DailyCardStatus {
  ACTIVE
  CLAIMABLE
  CLAIMED
  EXPIRED
}

enum DailyCardTaskType {
  TRAIN_UNITS
  COMPLETE_BUILDING
  RAID_BARBARIAN
  SCOUT_TARGET
  SEND_REINFORCEMENT
}

enum DailyRewardType {
  RESOURCES
}

enum RenownSource {
  CONSTRUCTION
  CONQUEST
  COMBAT
  RANKING_BONUS
}

enum OnboardingStatus {
  ACTIVE
  COMPLETED
}

enum OnboardingStep {
  UPGRADE_CASTLE_LEVEL_2
  BUILD_BARRACKS
  TRAIN_TROOPS
  UPGRADE_CASTLE_LEVEL_3
  BUILD_WATCHTOWER
  ATTACK_BARBARIAN
}

enum VillageOriginKind {
  STANDARD
  ONBOARDING_NARRATIVE
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String   @map("display_name")
  password    String
  renownXp    Int      @default(0) @map("renown_xp")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  sessions              Session[]
  villages              Village[]
  worldSeeds            WorldSeedState[]
  worldMemberships      WorldMembership[]
  crownBalances         CrownBalance[]
  onboardingStates      OnboardingState[]
  gloryLedgers          GloryLedger[]
  finalRankingSnapshots WorldFinalRankingSnapshot[]
  renownLedgers         RenownLedger[]
  rankingCycleTitles    RankingCycleTitleAward[]
  cosmeticAwards        UserWorldCosmeticAward[]
  friendshipsRequested  Friendship[]                @relation("FriendshipRequester")
  friendshipsReceived   Friendship[]                @relation("FriendshipRecipient")

  @@map("user")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @map("refresh_token_hash")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model World {
  id              String      @id
  name            String
  status          WorldStatus @default(PLANNED)
  config          Json        @default("{}")
  gridWidth       Int         @default(500)
  gridHeight      Int         @default(500)
  continentWidth  Int         @default(100) @map("continent_width")
  continentHeight Int         @default(100) @map("continent_height")
  startedAt       DateTime?   @map("started_at") @db.Timestamptz(3)
  endsAt          DateTime?   @map("ends_at") @db.Timestamptz(3)
  plannedOpenAt   DateTime?   @map("planned_open_at") @db.Timestamptz(3)
  inscriptionPhaseTransitionedAt DateTime? @map("inscription_phase_transitioned_at") @db.Timestamptz(3)
  archivedAt      DateTime?   @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  villages               Village[]
  memberships            WorldMembership[]
  seedStates             WorldSeedState[]
  chunkStates            ChunkSpawnState[]
  zoneCapacities         ZoneCapacity[]
  pendingConquests       PendingConquest[]
  onboardingStates       OnboardingState[]
  gloryLedgers           GloryLedger[]
  finalRankingSnapshots  WorldFinalRankingSnapshot[]
  gloryCycleSnapshots    GloryCycleSnapshot[]
  cosmeticAwards         UserWorldCosmeticAward[]
  friendships            Friendship[]

  @@index([status, plannedOpenAt])
  @@index([status, startedAt])
  @@index([status, endsAt])
  @@map("world")
}

model Village {
  id                         String            @id @default(cuid())
  worldId                    String            @map("world_id")
  userId                     String?           @map("user_id")
  name                       String
  x                          Int
  y                          Int
  isBarbarian                Boolean           @default(false) @map("is_barbarian")
  originKind                 VillageOriginKind @default(STANDARD) @map("origin_kind")
  tier                       String?
  label                      VillageLabel?
  barbarianTroopsLastRegenTs DateTime?         @map("barbarian_troops_last_regen_ts") @db.Timestamptz(3)
  conqueredAt                DateTime?         @map("conquered_at") @db.Timestamptz(3)
  createdAt                  DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  world                     World                  @relation(fields: [worldId], references: [id], onDelete: Cascade)
  user                      User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildings                 Building[]
  resourceStock             ResourceStock?
  population                Population?
  unitInventory             UnitInventory[]
  unitTraining              UnitTraining[]
  strategyConfig            VillageStrategyConfig?
  garrisons                 Garrison[]             @relation("VillageGarrison")
  sentReinforcements        Garrison[]             @relation("OriginVillageGarrison")
  pendingConquestAttacks    PendingConquest[]      @relation("PendingConquestAttacker")
  pendingConquestTargets    PendingConquest[]      @relation("PendingConquestTarget")
  onboardingNarrativeTarget OnboardingState?       @relation("OnboardingNarrativeTarget")

  @@unique([worldId, x, y])
  @@index([userId])
  @@index([worldId])
  @@index([worldId, userId])
  @@index([worldId, isBarbarian])
  @@index([worldId, tier])
  @@map("village")
}

model Building {
  id        String    @id @default(cuid())
  villageId String    @map("village_id")
  type      String
  level     Int       @default(1)
  startTime DateTime? @map("start_time") @db.Timestamptz(3)
  endTime   DateTime? @map("end_time") @db.Timestamptz(3)
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId, type])
  @@map("building")
}

model ResourceStock {
  villageId    String   @id @map("village_id")
  wood         Int      @default(0)
  stone        Int      @default(0)
  iron         Int      @default(0)
  maxPerType   Int      @default(1000) @map("max_per_type")
  lastUpdateTs DateTime @default(now()) @map("last_update_ts") @db.Timestamptz(3)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@map("resource_stock")
}

model Population {
  villageId String @id @map("village_id")
  used      Int    @default(0)
  max       Int    @default(10)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@map("population")
}

model UnitInventory {
  villageId String @map("village_id")
  unitType  String @map("unit_type")
  quantity  Int    @default(0)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@id([villageId, unitType])
  @@map("unit_inventory")
}

model PendingConquest {
  id                String                @id @default(cuid())
  attackerVillageId String                @map("attacker_village_id")
  attackerUserId    String                @map("attacker_user_id")
  attackerNobleId   String?               @map("attacker_noble_id")
  targetVillageId   String                @map("target_village_id")
  worldId           String                @map("world_id")
  openedAt          DateTime              @default(now()) @map("opened_at") @db.Timestamptz(3)
  captureUntil      DateTime              @map("capture_until") @db.Timestamptz(3)
  status            PendingConquestStatus @default(OPEN)
  finalizeJobId     String?               @map("finalize_job_id")

  attackerVillage Village @relation("PendingConquestAttacker", fields: [attackerVillageId], references: [id], onDelete: Cascade)
  targetVillage   Village @relation("PendingConquestTarget", fields: [targetVillageId], references: [id], onDelete: Cascade)
  world           World   @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([captureUntil, status])
  @@index([worldId, status])
  @@index([targetVillageId, status])
  @@map("pending_conquest")
}

model UnitTraining {
  id            String           @id @default(cuid())
  villageId     String           @map("village_id")
  building      TrainingBuilding @default(BARRACKS)
  unitType      String           @map("unit_type")
  totalQty      Int              @map("total_qty")
  completedQty  Int              @default(0) @map("completed_qty")
  timePerUnitMs Int              @map("time_per_unit_ms")
  nextUnitEta   DateTime         @map("next_unit_eta_ts") @db.Timestamptz(3)
  version       Int              @default(0)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([villageId, building, unitType])
  @@index([villageId])
  @@index([villageId, building])
  @@map("unit_training")
}

model WorldSeedState {
  userId   String    @map("user_id")
  worldId  String    @map("world_id")
  seeded   Boolean   @default(false)
  seededAt DateTime? @map("seeded_at") @db.Timestamptz(3)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@id([userId, worldId])
  @@map("world_seed_state")
}

model ChunkSpawnState {
  worldId       String    @map("world_id")
  cx            Int
  cy            Int
  lastSeededAt  DateTime? @map("last_seeded_at") @db.Timestamptz(3)
  seedVersion   Int       @default(1) @map("seed_version")
  existingCount Int       @default(0) @map("existing_count")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@id([worldId, cx, cy])
  @@index([worldId])
  @@map("chunk_spawn_state")
}

model EventOutbox {
  id           String    @id @default(cuid())
  kind         String
  aggregateId  String    @map("aggregate_id")
  payload      Json
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  dispatchedAt DateTime? @map("dispatched_at") @db.Timestamptz(3)

  @@index([dispatchedAt])
  @@map("event_outbox")
}

model DailyCard {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  worldId         String          @map("world_id")
  dayKey          String          @map("day_key")
  status          DailyCardStatus @default(ACTIVE)
  rewardType      DailyRewardType @default(RESOURCES) @map("reward_type")
  rewardWood      Int             @default(120) @map("reward_wood")
  rewardStone     Int             @default(120) @map("reward_stone")
  rewardIron      Int             @default(120) @map("reward_iron")
  rewardVillageId String?         @map("reward_village_id")
  claimedAt       DateTime?       @map("claimed_at") @db.Timestamptz(3)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  tasks DailyCardTask[]

  @@unique([userId, worldId, dayKey])
  @@index([userId, worldId, status])
  @@index([worldId])
  @@map("daily_card")
}

model DailyCardTask {
  id          String            @id @default(cuid())
  cardId      String            @map("card_id")
  type        DailyCardTaskType
  label       String
  progress    Int               @default(0)
  target      Int               @default(1)
  completedAt DateTime?         @map("completed_at") @db.Timestamptz(3)
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  card DailyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, type])
  @@index([cardId])
  @@map("daily_card_task")
}

model DailyCardProgressEvent {
  eventOutboxId String   @id @map("event_outbox_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("daily_card_progress_event")
}

model DailyOyez {
  id          String   @id @default(cuid())
  worldId     String   @map("world_id")
  dayKey      String?  @map("day_key")
  title       String
  description String
  theme       String
  startsAt    DateTime @map("starts_at") @db.Timestamptz(3)
  endsAt      DateTime @map("ends_at") @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([worldId, dayKey])
  @@index([worldId, startsAt, endsAt])
  @@map("daily_oyez")
}

model OnboardingState {
  id                       String           @id @default(cuid())
  userId                   String           @map("user_id")
  worldId                  String           @map("world_id")
  firstVillageId           String           @map("first_village_id")
  narrativeTargetVillageId String?          @unique @map("narrative_target_village_id")
  status                   OnboardingStatus @default(ACTIVE)
  currentStep              OnboardingStep   @default(UPGRADE_CASTLE_LEVEL_2) @map("current_step")
  initialRewardApplied     Boolean          @default(false) @map("initial_reward_applied")
  initialRewardAppliedAt   DateTime?        @map("initial_reward_applied_at") @db.Timestamptz(3)
  completionRewardApplied  Boolean          @default(false) @map("completion_reward_applied")
  completionRewardAppliedAt DateTime?       @map("completion_reward_applied_at") @db.Timestamptz(3)
  completedAt              DateTime?        @map("completed_at") @db.Timestamptz(3)
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  world                  World                    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  narrativeTargetVillage Village?                 @relation("OnboardingNarrativeTarget", fields: [narrativeTargetVillageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  steps                  OnboardingStepProgress[]

  @@unique([userId, worldId])
  @@index([worldId, status])
  @@map("onboarding_state")
}

model OnboardingStepProgress {
  id                String         @id @default(cuid())
  onboardingStateId String         @map("onboarding_state_id")
  step              OnboardingStep
  eventOutboxId     String?        @map("event_outbox_id")
  completedAt       DateTime       @default(now()) @map("completed_at") @db.Timestamptz(3)

  onboardingState OnboardingState @relation(fields: [onboardingStateId], references: [id], onDelete: Cascade)

  @@unique([onboardingStateId, step])
  @@unique([eventOutboxId])
  @@index([onboardingStateId])
  @@map("onboarding_step_progress")
}

model OnboardingProgressEvent {
  eventOutboxId String   @id @map("event_outbox_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("onboarding_progress_event")
}

model WorldMembership {
  userId      String    @map("user_id")
  worldId     String    @map("world_id")
  role        WorldRole @default(PLAYER)
  joinedAt    DateTime  @default(now()) @map("joined_at") @db.Timestamptz(3)
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  shieldBrokenAt DateTime? @map("shield_broken_at") @db.Timestamptz(3)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@id([userId, worldId])
  @@index([worldId])
  @@map("world_membership")
}

model ZoneCapacity {
  worldId      String   @map("world_id")
  zoneIndex    Int      @map("zone_index")
  villageCount Int      @default(0) @map("village_count")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@id([worldId, zoneIndex])
  @@index([worldId])
  @@map("zone_capacity")
}

model CrownBalance {
  userId       String   @map("user_id")
  worldId      String   @map("world_id")
  balance      Int      @default(0)
  lastUpdateTs DateTime @default(now()) @map("last_update_ts") @db.Timestamptz(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, worldId])
  @@index([userId])
  @@index([worldId])
  @@map("crown_balance")
}

model Expedition {
  id                             String           @id @default(cuid())
  worldId                        String           @map("world_id")
  attackerVillageId              String           @map("attacker_village_id")
  reinforcementOriginVillageId   String?          @map("reinforcement_origin_village_id")
  reinforcementRecallActorUserId String?          @map("reinforcement_recall_actor_user_id")
  kind                           ExpeditionKind   @default(ATTACK)
  targetKind                     TargetKind       @map("target_kind")
  targetRefId                    String           @map("target_ref_id")
  targetX                        Int              @map("target_x")
  targetY                        Int              @map("target_y")
  units                          Json
  status                         ExpeditionStatus @default(EN_ROUTE)
  departAt                       DateTime         @map("depart_at") @db.Timestamptz(3)
  arrivalAt                      DateTime         @map("arrival_at") @db.Timestamptz(3)
  outboundTravelMs               Int              @map("outbound_travel_ms")
  attackerKingdomPowerSnapshot   Int?             @map("attacker_kingdom_power_snapshot")
  defenderKingdomPowerSnapshot   Int?             @map("defender_kingdom_power_snapshot")
  defenderKingdomPowerSnapshots  Json?            @map("defender_kingdom_power_snapshots")
  returnAt                       DateTime?        @map("return_at") @db.Timestamptz(3)
  recalled                       Boolean          @default(false)
  reportId                       String?          @unique @map("report_id")
  scoutReportId                  String?          @unique @map("scout_report_id")
  survivingUnits                 Json?            @map("surviving_units")
  loot                           Json?            @map("loot")
  createdAt                      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  report      CombatReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  scoutReport ScoutReport?  @relation(fields: [scoutReportId], references: [id], onDelete: SetNull)

  @@index([attackerVillageId])
  @@index([status])
  @@index([arrivalAt])
  @@index([returnAt])
  @@map("expedition")
}

model CombatReport {
  id                  String     @id @default(cuid())
  worldId             String     @map("world_id")
  attackerVillageId   String     @map("attacker_village_id")
  attackerVillageName String?    @map("attacker_village_name")
  attackerX           Int?       @map("attacker_x")
  attackerY           Int?       @map("attacker_y")
  attackerUserId      String     @map("attacker_user_id")
  defenderVillageId   String?    @map("defender_village_id")
  defenderVillageName String?    @map("defender_village_name")
  defenderX           Int?       @map("defender_x")
  defenderY           Int?       @map("defender_y")
  defenderUserId      String?    @map("defender_user_id")
  observerUserId      String?    @map("observer_user_id")
  targetKind          TargetKind @map("target_kind")
  targetX             Int        @map("target_x")
  targetY             Int        @map("target_y")

  loot Json

  totalUnitsAttacker Json  @default("{}") @map("total_units_attacker")
  totalUnitsDefender Json? @map("total_units_defender")

  lossesAttacker Json  @map("losses_attacker")
  lossesDefender Json? @map("losses_defender")

  isRead           Boolean @default(false) @map("is_read")
  readByAttacker   Boolean @default(false) @map("read_by_attacker")
  readByDefender   Boolean @default(false) @map("read_by_defender")
  readByObserver   Boolean @default(false) @map("read_by_observer")
  hiddenByAttacker Boolean @default(false) @map("hidden_by_attacker")
  hiddenByDefender Boolean @default(false) @map("hidden_by_defender")
  hiddenByObserver Boolean @default(false) @map("hidden_by_observer")

  timestamp DateTime @default(now()) @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  details   Json

  expedition   Expedition?
  gloryLedgers GloryLedger[]

  @@index([attackerUserId])
  @@index([defenderUserId])
  @@index([observerUserId])
  @@index([worldId])
  @@index([timestamp])
  @@map("combat_report")
}

model GloryLedger {
  id                     String        @id @default(cuid())
  worldId                String        @map("world_id")
  signal                 RankingSignal
  scorerUserId           String        @map("scorer_user_id")
  /// Denormalized opponent id, intentionally without an FK relation. The Glory
  /// ledger is durable and append-only: rows must survive opponent account
  /// deletion so historical weekly/all-time standings stay reproducible. No
  /// cleanup is tied to the opponent lifecycle; display names are resolved
  /// lazily and tolerate a missing user.
  opponentUserId         String        @map("opponent_user_id")
  pairKey                String        @map("pair_key")
  combatReportId         String        @map("combat_report_id")
  rawPoints              Int           @map("raw_points")
  pairRawPoints24hBefore Int           @default(0) @map("pair_raw_points_24h_before")
  effectiveRawPoints     Int           @map("effective_raw_points")
  opponentMultiplier     Float         @map("opponent_multiplier")
  points                 Int
  occurredAt             DateTime      @default(now()) @map("occurred_at") @db.Timestamptz(3)
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  world        World        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  scorer       User         @relation(fields: [scorerUserId], references: [id], onDelete: Cascade)
  combatReport CombatReport @relation(fields: [combatReportId], references: [id])

  @@unique([combatReportId, signal, scorerUserId, opponentUserId], map: "glory_ledger_report_signal_scorer_opponent_key")
  @@index([worldId, signal, occurredAt])
  @@index([worldId, signal, scorerUserId])
  @@index([worldId, pairKey, occurredAt])
  @@map("glory_ledger")
}

model ScoutReport {
  id              String           @id @default(cuid())
  worldId         String           @map("world_id")
  scoutVillageId  String           @map("scout_village_id")
  scoutUserId     String           @map("scout_user_id")
  targetVillageId String?          @map("target_village_id")
  targetKind      TargetKind       @map("target_kind")
  targetX         Int              @map("target_x")
  targetY         Int              @map("target_y")
  targetName      String?          @map("target_name")
  targetTier      String?          @map("target_tier")
  units           Json
  resources       Json
  strategy        VillageStrategy?
  isRead          Boolean          @default(false) @map("is_read")
  hidden          Boolean          @default(false)
  timestamp       DateTime         @default(now()) @db.Timestamptz(3)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  details         Json

  expedition Expedition?

  @@index([scoutUserId])
  @@index([worldId])
  @@index([timestamp])
  @@map("scout_report")
}

enum VillageStrategy {
  FORTRESS
  RAIDERS
  ECONOMIC
  BALANCED
}

model VillageStrategyConfig {
  id             String          @id @default(cuid())
  villageId      String          @unique @map("village_id")
  strategy       VillageStrategy
  lastChangedAt  DateTime        @default(now()) @map("last_changed_at") @db.Timestamptz(3)
  changeCost     Int             @default(0) @map("change_cost")
  cooldownEndsAt DateTime?       @map("cooldown_ends_at") @db.Timestamptz(3)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([strategy])
  @@map("village_strategy_config")
}

enum IntelSourceKind {
  SCOUT
  COMBAT_WIN
}

model VillageIntel {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  worldId         String           @map("world_id")
  targetVillageId String           @map("target_village_id")
  sourceKind      IntelSourceKind  @map("source_kind")
  sourceReportId  String           @map("source_report_id")
  units           Json
  resources       Json
  wallLevel       Int?             @map("wall_level")
  strategy        VillageStrategy?
  targetName      String?          @map("target_name")
  targetX         Int              @map("target_x")
  targetY         Int              @map("target_y")
  targetTier      String?          @map("target_tier")
  seenAt          DateTime         @map("seen_at") @db.Timestamptz(3)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([userId, worldId, targetVillageId])
  @@index([userId, worldId])
  @@map("village_intel")
}

/// Private map markers (cf. docs/gameplay/26-private-map-markers.md, run 085).
enum MapMarkerKind {
  TO_SCOUT
  TARGET
  DANGER
  FUTURE_VILLAGE
  INTEREST
  NOTE
}

/// Player-private strategic memory pinned to a free tile (worldId, x, y),
/// independent of the tile's content. worldId is denormalised (no FK cascade
/// from Village) — purged explicitly on world archive, like VillageIntel.
model MapMarker {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  worldId   String        @map("world_id")
  x         Int
  y         Int
  kind      MapMarkerKind
  note      String?
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([userId, worldId, x, y])
  @@index([userId, worldId])
  @@index([worldId])
  @@map("map_marker")
}

model Garrison {
  id              String @id @default(cuid())
  villageId       String @map("village_id")
  originVillageId String @map("origin_village_id")
  unitType        String @map("unit_type")
  quantity        Int    @default(0)

  village       Village @relation("VillageGarrison", fields: [villageId], references: [id], onDelete: Cascade)
  originVillage Village @relation("OriginVillageGarrison", fields: [originVillageId], references: [id], onDelete: Cascade)

  @@unique([villageId, originVillageId, unitType])
  @@index([villageId])
  @@index([originVillageId])
  @@map("garrison")
}

enum FriendshipStatus {
  PENDING
  ACTIVE
}

/// Defensive-friends link between two players on one world (cf.
/// docs/gameplay/20-defensive-friends.md). PENDING until the recipient accepts;
/// only ACTIVE grants cross-player reinforcement rights. Cap 5 ACTIVE per side
/// enforced application-side (DEFENSIVE_FRIENDS_CAP). Bi-directional indexes
/// cover the cap query from either side of the pair.
model Friendship {
  id              String           @id @default(cuid())
  worldId         String           @map("world_id")
  requesterUserId String           @map("requester_user_id")
  recipientUserId String           @map("recipient_user_id")
  status          FriendshipStatus @default(PENDING)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  acceptedAt      DateTime?        @map("accepted_at") @db.Timestamptz(3)

  world         World @relation(fields: [worldId], references: [id], onDelete: Cascade)
  requesterUser User  @relation("FriendshipRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  recipientUser User  @relation("FriendshipRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([worldId, requesterUserId, recipientUserId])
  @@index([worldId, recipientUserId, status])
  @@index([worldId, requesterUserId, status])
  @@map("friendship")
}

enum ReinforcementReportType {
  STATIONED
  RETURNED
}

enum CaravanReportType {
  ARRIVED
  RETURNED
}

enum InboxKind {
  REINFORCEMENT
  CARAVAN
}

/// Business fact for a reinforcement movement (arrival or homecoming).
/// Carries no attacker/defender, no losses, no loot, no victory outcome.
model ReinforcementReport {
  id                String                  @id @default(cuid())
  worldId           String                  @map("world_id")
  type              ReinforcementReportType
  originVillageId   String                  @map("origin_village_id")
  originVillageName String?                 @map("origin_village_name")
  originX           Int                     @map("origin_x")
  originY           Int                     @map("origin_y")
  hostVillageId     String                  @map("host_village_id")
  hostVillageName   String?                 @map("host_village_name")
  hostX             Int                     @map("host_x")
  hostY             Int                     @map("host_y")
  units             Json
  actorUserId       String?                 @map("actor_user_id")
  timestamp         DateTime                @default(now()) @db.Timestamptz(3)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)

  inboxEntries InboxEntry[]

  @@index([worldId])
  @@index([timestamp])
  @@map("reinforcement_report")
}

/// Business fact for a resource caravan delivery or recalled homecoming.
/// EventOutbox remains realtime-only; this table is the persistent archive.
model CaravanReport {
  id                String            @id @default(cuid())
  worldId           String            @map("world_id")
  expeditionId      String            @map("expedition_id")
  type              CaravanReportType
  originVillageId   String            @map("origin_village_id")
  originVillageName String?           @map("origin_village_name")
  originX           Int               @map("origin_x")
  originY           Int               @map("origin_y")
  targetVillageId   String            @map("target_village_id")
  targetVillageName String?           @map("target_village_name")
  targetX           Int               @map("target_x")
  targetY           Int               @map("target_y")
  resources         Json
  credited          Json
  returned          Json
  lost              Json
  porters           Int               @default(0)
  recalled          Boolean           @default(false)
  timestamp         DateTime          @default(now()) @db.Timestamptz(3)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  inboxEntries InboxEntry[]

  @@unique([expeditionId, type])
  @@index([worldId])
  @@index([timestamp])
  @@map("caravan_report")
}

/// Per-recipient inbox state. One row per distinct recipient of a report.
/// Typed FK per domain (no polymorphic JSON `reportId`).
model InboxEntry {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  worldId               String    @map("world_id")
  kind                  InboxKind
  reinforcementReportId String?   @map("reinforcement_report_id")
  caravanReportId       String?   @map("caravan_report_id")
  isRead                Boolean   @default(false) @map("is_read")
  hidden                Boolean   @default(false)
  timestamp             DateTime  @default(now()) @db.Timestamptz(3)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  reinforcementReport ReinforcementReport? @relation(fields: [reinforcementReportId], references: [id], onDelete: Cascade)
  caravanReport       CaravanReport?       @relation(fields: [caravanReportId], references: [id], onDelete: Cascade)

  @@unique([userId, reinforcementReportId])
  @@unique([userId, caravanReportId])
  @@index([userId, worldId])
  @@index([timestamp])
  @@map("inbox_entry")
}

model WorldFinalRankingSnapshot {
  id         String             @id @default(cuid())
  worldId    String             @map("world_id")
  userId     String             @map("user_id")
  signal     FinalRankingSignal
  rank       Int
  score      Int
  snapshotAt DateTime           @map("snapshot_at") @db.Timestamptz(3)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([worldId, signal, userId], map: "world_final_ranking_snapshot_world_signal_user_key")
  @@index([worldId, signal, rank])
  @@map("world_final_ranking_snapshot")
}

/// Frozen leaderboard of one closed weekly Glory cycle (run 068). `entries` is a
/// JSONB top-N `[{userId, displayName, score, rank}]`. Bound to a world, so it
/// can be purged with the world wipe (run 065). The rank-1 champions are also
/// materialized as durable RankingCycleTitleAward rows that survive the wipe.
model GloryCycleSnapshot {
  id           String        @id @default(cuid())
  worldId      String        @map("world_id")
  signal       RankingSignal
  cycleIndex   Int           @map("cycle_index")
  cycleStartAt DateTime      @map("cycle_start_at") @db.Timestamptz(3)
  cycleEndAt   DateTime      @map("cycle_end_at") @db.Timestamptz(3)
  closedAt     DateTime      @map("closed_at") @db.Timestamptz(3)
  entries      Json
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@unique([worldId, signal, cycleIndex], map: "glory_cycle_snapshot_world_signal_index_key")
  @@index([worldId, signal, cycleEndAt])
  @@map("glory_cycle_snapshot")
}

/// Temporary weekly championship title awarded to the rank-1 player of a closed
/// Glory cycle (run 068). `validUntilAt` (= next cycle's end) bounds the
/// "active" display window, but the row is permanent — a player keeps their
/// title history. Cosmetic only.
///
/// `worldId` is denormalized WITHOUT a `World` FK relation (same rationale as
/// `GloryLedger.opponentUserId`): the title must survive the destructive world
/// wipe (run 065) by construction, so it must not cascade-delete when the world
/// is purged. `worldDisplayName` snapshots the readable name at award time so
/// the title stays legible even after the world is gone.
model RankingCycleTitleAward {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  worldId          String        @map("world_id")
  signal           RankingSignal
  cycleIndex       Int           @map("cycle_index")
  worldDisplayName String        @map("world_display_name")
  cycleEndAt       DateTime      @map("cycle_end_at") @db.Timestamptz(3)
  validUntilAt     DateTime      @map("valid_until_at") @db.Timestamptz(3)
  awardedAt        DateTime      @map("awarded_at") @db.Timestamptz(3)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, worldId, signal, cycleIndex], map: "ranking_cycle_title_award_user_world_signal_index_key")
  @@index([userId, validUntilAt])
  @@map("ranking_cycle_title_award")
}

/// Permanent, account-global cosmetic title earned by a top-1 champion when a
/// world reaches ENDED (run 067). Attached to the user account, NOT the world
/// session: `worldDisplayName` is snapshotted at award time so the label stays
/// readable even after the world is renamed or purged (run 065 explicitly
/// excludes this table from the destructive wipe). Cosmetic only — never a
/// gameplay bonus (spec 24 § Rewards).
model UserWorldCosmeticAward {
  id               String            @id @default(cuid())
  userId           String            @map("user_id")
  worldId          String            @map("world_id")
  kind             CosmeticAwardKind
  worldDisplayName String            @map("world_display_name")
  awardedAt        DateTime          @map("awarded_at") @db.Timestamptz(3)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@unique([userId, worldId, kind], map: "user_world_cosmetic_award_user_world_kind_key")
  @@index([userId])
  @@map("user_world_cosmetic_award")
}

model RenownLedger {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  source    RenownSource
  xp        Int
  worldId   String?      @map("world_id")
  dedupKey  String       @unique @map("dedup_key")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("renown_ledger")
}
