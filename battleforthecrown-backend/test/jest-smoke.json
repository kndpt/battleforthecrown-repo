{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "smoke\\.spec\\.ts$",
  "setupFiles": ["<rootDir>/jest-smoke-setup.ts"],
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testTimeout": 30000,
  "maxWorkers": 10,
  "testSequencer": "<rootDir>/jest-smoke-sequencer.js"
}
