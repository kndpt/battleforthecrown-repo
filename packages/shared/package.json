      "types": "./dist/village/buildings.d.ts",
      "default": "./dist/village/buildings.js"
    },
    "./army": {
      "types": "./dist/army/index.d.ts",
      "default": "./dist/army/index.js"
    },
    "./combat": {
      "types": "./dist/combat/index.d.ts",
      "default": "./dist/combat/index.js"
    },
    "./crowns": {
      "types": "./dist/crowns/index.d.ts",
      "default": "./dist/crowns/index.js"
    },
    "./power": {
      "types": "./dist/power/index.d.ts",
      "default": "./dist/power/index.js"
    },
    "./world": {
      "types": "./dist/world/index.d.ts",
      "default": "./dist/world/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
